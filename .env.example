# Galaxy credentials (required for live mode). Leave blank to stay in mock mode.
VITE_GALAXY_API_KEY=api_key_iatest
VITE_GALAXY_API_SECRET_KEY=GaLxAiDviTS12*

# SmartConfig endpoint - returns galaxyBaseUrl, rubricPath, campaignId,
# languageCode, countryCode, rubricId. Required in live mode.
# In dev, use the Vite proxy path to dodge CORS, e.g. `/galaxy-proxy/smartconfig`.
VITE_SMARTCONFIG_URL=

# Optional override for the Vite dev proxy upstream (defaults to Galaxy prod).
VITE_GALAXY_PROXY_TARGET=https://galaxy-api.galaxydve.com

# Supabase (already provisioned)
VITE_SUPABASE_URL=
VITE_SUPABASE_SUPABASE_ANON_KEY=
